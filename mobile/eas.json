{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.0.58:3001/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REEMPLAZAR-con-tu-backend.onrender.com/api",
        "EXPO_PUBLIC_APP_URL": "https://app.handicapp.com",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://REEMPLAZAR-con-tu-backend.onrender.com/api",
        "EXPO_PUBLIC_APP_URL": "https://app.handicapp.com",
        "EXPO_PUBLIC_SENTRY_DSN": ""
      }
    }
  },
  "submit": {
    "production": {}
  }
}
