{
  "expo": {
    "name": "HandicApp",
    "slug": "handicapp",
    "scheme": "handicapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#f9fafb",
      "dark": {
        "image": "./assets/splash-logo.png",
        "backgroundColor": "#0b0b0c"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.handicapp.app",
      "associatedDomains": [
        "applinks:app.handicapp.com"
      ]
    },
    "android": {
      "package": "com.handicapp.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.handicapp.com",
              "pathPrefix": "/invitacion"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "HandicApp necesita acceso a tu galería para subir fotos de caballos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f1f3d",
          "sounds": []
        }
      ],
      "@sentry/react-native",
      "expo-font"
    ]
  }
}
